// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectRole {
  PROJECT_MANAGER
  DEVELOPER
  DESIGNER
  TESTER
  OTHER
}

enum DealStatus {
  PROPOSAL
  NEGOTIATION
  APPROVED
  REJECTED
}

enum TimelineEventType {
  MILESTONE
  TASK
  MEETING
  DELIVERABLE
  NOTE
}

enum TimelineStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
}

enum Module {
  INVENTORY
  FINANCE
  PROJECTS
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  inventoryItems       InventoryItem[]
  financeTransactions  FinanceTransaction[]
  projects             Project[]                    @relation("ProjectCreator")
  projectAssignments   ProjectAssignment[]
  timelineAssignments  ProjectTimeline[]            @relation("TimelineAssignee")
  projectUpdates       ProjectUpdate[]
  activityLogs         ActivityLog[]
  assignedBy           ProjectAssignment[]          @relation("AssignmentCreator")
  notifications        Notification[]
  createdInvoices      Invoice[]                @relation("InvoiceCreator")
  recurringExpenseTemplates RecurringExpenseTemplate[]
}

model InventoryItem {
  id            String    @id @default(cuid())
  name          String
  category      String
  quantity      Int
  purchaseDate  DateTime
  supplier      String
  unitPrice     Decimal   @db.Decimal(10, 2)
  totalValue    Decimal   @db.Decimal(10, 2)
  imageUrl      String?   @db.Text
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model FinanceTransaction {
  id          String    @id @default(cuid())
  title       String
  type        String    // INCOME or EXPENSE
  amount      Decimal   @db.Decimal(10, 2)
  date        DateTime
  description String?   @db.Text
  category    String?
  receiptUrl  String?   @db.Text
  /// When category is salaries — shown on the printable salary slip.
  salaryEmployeeName  String?
  salaryBankAccount   String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recurringSourceId String?
  recurringSource   RecurringExpenseTemplate? @relation(fields: [recurringSourceId], references: [id], onDelete: SetNull)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([date])
  @@index([recurringSourceId])
}

/// Saved monthly expense (rent, salaries, etc.) — post to the ledger with one click per month.
model RecurringExpenseTemplate {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  category     String
  amount       Decimal  @db.Decimal(10, 2)
  /// Optional monthly allocation cap for budget tracking; if null, `amount` is used as the planned budget.
  monthlyBudgetAmount Decimal? @db.Decimal(10, 2)
  dayOfMonth   Int
  isActive     Boolean  @default(true)
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions FinanceTransaction[]

  @@index([userId])
  @@index([isActive])
}

model Project {
  id          String              @id @default(cuid())
  name        String
  description String?             @db.Text
  status      ProjectStatus       @default(PLANNING)
  priority    ProjectPriority     @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?            @db.Decimal(10, 2)
  clientName  String?
  createdBy   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  creator     User                @relation("ProjectCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignments ProjectAssignment[]
  deals       ProjectDeal[]
  timelines   ProjectTimeline[]
  updates     ProjectUpdate[]
  invoices    Invoice[]

  @@index([createdBy])
  @@index([status])
  @@index([priority])
}

model ProjectAssignment {
  id          String        @id @default(cuid())
  projectId   String
  userId      String
  role        ProjectRole
  assignedAt  DateTime      @default(now())
  assignedBy  String

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assigner    User          @relation("AssignmentCreator", fields: [assignedBy], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectDeal {
  id                String      @id @default(cuid())
  projectId         String
  title             String
  description       String?     @db.Text
  amount            Decimal     @db.Decimal(10, 2)
  currency          String      @default("USD")
  dealStatus        DealStatus  @default(PROPOSAL)
  clientName        String?
  contactEmail      String?
  contactPhone      String?
  expectedCloseDate DateTime?
  closedDate        DateTime?
  createdBy         String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([dealStatus])
}

model ProjectTimeline {
  id          String              @id @default(cuid())
  projectId   String
  title       String
  description String?             @db.Text
  eventType   TimelineEventType
  startDate   DateTime
  endDate     DateTime
  status      TimelineStatus      @default(PENDING)
  assignedTo  String?
  createdBy   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?               @relation("TimelineAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actionType  ActionType
  module      Module
  recordId    String
  performedBy String
  timestamp   DateTime @default(now())
  oldValues   Json?    @default("{}")
  newValues  Json?     @default("{}")
  description String?  @db.Text

  user        User     @relation(fields: [performedBy], references: [id], onDelete: Cascade)

  @@index([performedBy])
  @@index([module])
  @@index([timestamp])
  @@index([recordId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // PROJECT_ASSIGNED, etc.
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  projectId     String
  clientName    String
  clientEmail   String?
  clientAddress String?       @db.Text
  issueDate     DateTime
  dueDate       DateTime?
  currency      String        @default("PKR")
  taxRate       Decimal       @db.Decimal(5, 2) @default(0)
  status        String        @default("DRAFT")
  subtotal      Decimal       @db.Decimal(12, 2) @default(0)
  taxAmount     Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2) @default(0)
  notes         String?       @db.Text
  terms         String?       @db.Text
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]
  creator       User          @relation("InvoiceCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([invoiceNumber])
  @@index([status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(12, 2)
  lineTotal   Decimal   @db.Decimal(12, 2)

  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}


